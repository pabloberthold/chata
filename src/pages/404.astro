<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Redirigiendo...</title>
  <script>
    const path = window.location.pathname;
    const match = path.match(/\/chat\/(.+)/);
    if (match) {
      window.location.replace("/chata/?chat=" + encodeURIComponent(match[1]));
    } else {
      window.location.replace("/chata/");
    }
  </script>
</head>
<body>
  <p>Redirigiendo...</p>
</body>
</html>
